{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Memo",
  "version": "0.1.0",
  "identifier": "com.alaoui.memo",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
    {
      "title": "Memo",
      "width": 800,
      "height": 600,
      "resizable": true,
      "fullscreen": false
    },
    {
      "label": "popup",
      "title": "",
      "width": 320,
      "height": 150,
      "resizable": false,
      "decorations": false,
      "alwaysOnTop": true,
      "visible": false,
      "transparent": true,
      "skipTaskbar": true,
      "shadow": false,
      "url": "popup.html",
      "x": 9999,
      "y": 9999
    }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "tray": {},
    "autostart": null,
    "single-instance": null
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}